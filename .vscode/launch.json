{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "CinemaApplication",
      "request": "launch",
      "mainClass": "com.jiayue.cinema.CinemaApplication",
      "projectName": "cinema",
      "cwd": "${workspaceFolder}/backend"
    },
    {
      "type": "java",
      "name": "Debug (Attach)",
      "request": "attach",
      "hostName": "localhost",
      "port": 5005
    },
    {
      "type": "java",
      "name": "Current File",
      "request": "launch",
      "mainClass": "${file}"
    }
  ]
}